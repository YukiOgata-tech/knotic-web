# Supabase (Client-safe)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Either one is accepted (publishable preferred)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (Server-only)
# Either one is accepted (secret preferred)
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase CLI (local dev / CI only — do NOT commit the actual token)
# Dashboard: https://supabase.com/dashboard/account/tokens
# Used by: `npx supabase functions deploy`, `npx supabase secrets set`, etc.
SUPABASE_ACCESS_TOKEN=sbp_replace_me

# App URL (used for auth redirects / Stripe return URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (server-only, for indexing/chunk embeddings)
OPENAI_API_KEY=your-openai-api-key
# Keep this as text-embedding-3-small (schema uses vector(1536))
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Internal indexing runner API secret
INDEXER_RUNNER_SECRET=change-this-long-random-secret

# Stripe (server-only)
# test: sk_test_xxx / live: sk_live_xxx
STRIPE_SECRET_KEY=sk_test_replace_me
# Stripe webhook endpoint signing secret (whsec_xxx)
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe recurring price IDs (monthly)
STRIPE_PRICE_LITE_MONTHLY=price_replace_lite_monthly
STRIPE_PRICE_STANDARD_MONTHLY=price_replace_standard_monthly
STRIPE_PRICE_PRO_MONTHLY=price_replace_pro_monthly

# Internal billing webhook retry runner secret (cron/job)
BILLING_RUNNER_SECRET=change-this-billing-runner-secret

# Resend (contact form email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Knotic Contact <contact@your-domain.com>
RESEND_CONTACT_TO_EMAIL=you@your-domain.com
