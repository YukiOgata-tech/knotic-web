# Supabase (Client-safe)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Either one is accepted (publishable preferred)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (Server-only)
# Either one is accepted (secret preferred)
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: App URL for auth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (server-only, for indexing/chunk embeddings)
OPENAI_API_KEY=your-openai-api-key
# Keep this as text-embedding-3-small (schema uses vector(1536))
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Internal indexing runner API secret
INDEXER_RUNNER_SECRET=change-this-long-random-secret
